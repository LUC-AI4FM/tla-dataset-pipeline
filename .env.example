# Local Environment Overrides
# Copy this file to .env and fill in your local values
# The .env file is git-ignored and will NOT be committed

# GitHub API
GITHUB_TOKEN=your_github_personal_access_token_here

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
S3_BUCKET=your-local-test-bucket
AWS_REGION=us-east-2

# Optional: Override default paths if needed
# MANIFEST_INPUT=manifests/sources/sources_latest.jsonl
# DATA_OUTPUT=data/raw
# SCHEMA_PATH=data_contracts/schemas/source_record.schema.json
